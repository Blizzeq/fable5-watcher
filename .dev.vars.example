# Skopiuj ten plik do `.dev.vars` (gitignored) na potrzeby lokalnych testów `wrangler dev`.
# W produkcji DISCORD_WEBHOOK_URL ustawiasz przez `wrangler secret put`, a
# DISCORD_USER_ID jest w wrangler.toml ([vars]). Klucz API nie jest potrzebny.

DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/XXXX/YYYY"
DISCORD_USER_ID="123456789012345678"
